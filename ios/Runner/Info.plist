<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Taxímetro</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>taximetro</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- ============================================================ -->
	<!-- PERMISSÕES DE LOCALIZAÇÃO EM SEGUNDO PLANO (iOS 14+)        -->
	<!-- ============================================================ -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>O taxímetro precisa da sua localização para calcular a distância percorrida durante a corrida.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>O taxímetro precisa de acesso contínuo à localização mesmo em segundo plano para não interromper o cálculo da corrida.</string>

	<key>NSLocationAlwaysUsageDescription</key>
	<string>O taxímetro precisa de acesso à localização em segundo plano para continuar calculando a corrida enquanto você usa outros aplicativos.</string>

	<!-- Necessário para iOS 14+ habilitar background location -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>location</string>
		<string>processing</string>
	</array>

	<!-- Sensores de movimento -->
	<key>NSMotionUsageDescription</key>
	<string>O taxímetro usa sensores de movimento para detectar quando o veículo está parado e evitar cobranças indevidas.</string>

	<!-- Prevenir suspensão do GPS -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.taximetro.location.update</string>
	</array>

	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
</dict>
</plist>
